---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SideStarFields from '../components/SideStarFields.astro';
import SideOrbitals   from '../components/SideOrbitals.astro';
import '../styles/global.css';

interface Props {
  title:       string;
  description?: string;
  ogImage?:    string;
}

const {
  title,
  description = 'Priyanka Vijaybaskar — edge ML and computer vision engineer at CMU. Building perception systems for robots and spacecraft.',
  ogImage,
} = Astro.props;

// Canonical URL requires `site` to be set in astro.config.mjs for production
const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.href;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type"        content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />

    <title>{title}</title>

    <!--
      Prevent flash of wrong theme (FOUC):
      Runs synchronously before any paint, reads localStorage / system pref,
      and applies the .dark class if needed. The try/catch guards against
      environments where localStorage is blocked (e.g., private browsing).
    -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (stored === 'dark' || (!stored && prefersDark)) {
            document.documentElement.classList.add('dark');
          }
        } catch (_) {}
      })();
    </script>

    <!-- Fonts: preconnect first, then load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Skip link — invisible until focused -->
    <a href="#main-content" class="skip-link">Skip to content</a>

    <Header />

    <!-- Side starfields + orbital simulations: fixed viewport-edge panels, all pages -->
    <SideStarFields />
    <SideOrbitals />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
