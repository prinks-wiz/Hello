---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

interface Props {
  entry: CollectionEntry<'writing'>;
}

const { entry } = Astro.props;
const { title, summary, date, tags } = entry.data;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year:  'numeric',
    month: 'long',
    day:   'numeric',
  });
---
<BaseLayout title={`${title} — Writing`} description={summary}>
  <div class="max-w-[720px] mx-auto px-6 py-16">

    <nav aria-label="Breadcrumb" class="mb-10">
      <a
        href="/writing"
        class="font-mono text-xs text-subtle hover:text-accent transition-colors"
      >
        ← Writing
      </a>
    </nav>

    <header class="mb-12 border-b border-edge pb-8">
      <time
        class="font-mono text-xs text-subtle block mb-3"
        datetime={date.toISOString()}
      >
        {fmt(date)}
      </time>

      <h1 class="text-2xl font-semibold text-content mb-4 tracking-tight">
        {title}
      </h1>

      <p class="text-subtle leading-relaxed">{summary}</p>

      {tags && tags.length > 0 && (
        <ul class="flex flex-wrap gap-2 list-none m-0 p-0 mt-4" aria-label="Tags">
          {tags.map(tag => (
            <li>
              <span class="font-mono text-xs text-subtle border border-edge px-2 py-0.5">
                {tag}
              </span>
            </li>
          ))}
        </ul>
      )}
    </header>

    <article class="prose-content">
      <slot />
    </article>

  </div>
</BaseLayout>
