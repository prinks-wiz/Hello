---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('writing');
const sorted = posts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---
<BaseLayout
  title="Writing — Portfolio"
  description="Technical writing on ML, robotics, and systems engineering."
>
  <div class="max-w-[720px] mx-auto px-6 py-16">

    <SectionHeader number="03" title="WRITING" />

    <h1 class="text-2xl font-semibold text-content mb-12 tracking-tight">
      Writing
    </h1>

    <ul class="list-none m-0 p-0">
      {sorted.map(post => (
        <li class="border-b border-edge py-6">
          <article>
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <a href={`/writing/${post.slug}`} class="group block">
                  <h2 class="text-base font-medium text-content group-hover:text-accent transition-colors mb-2">
                    {post.data.title}
                  </h2>
                </a>
                <p class="text-sm text-subtle leading-relaxed mb-3">
                  {post.data.summary}
                </p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <ul class="flex flex-wrap gap-2 list-none m-0 p-0" aria-label="Tags">
                    {post.data.tags.map(tag => (
                      <li>
                        <span class="font-mono text-xs text-subtle border border-edge px-2 py-0.5">
                          {tag}
                        </span>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
              <time
                class="font-mono text-xs text-subtle shrink-0 mt-0.5"
                datetime={post.data.date.toISOString()}
              >
                {post.data.date.toLocaleDateString('en-US', {
                  year:  'numeric',
                  month: 'short',
                })}
              </time>
            </div>
          </article>
        </li>
      ))}
    </ul>

  </div>
</BaseLayout>
