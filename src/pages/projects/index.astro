---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('projects');

// Newest first; featured projects bubble to the top within same date
const sorted = all.sort((a, b) => {
  if (a.data.featured !== b.data.featured)
    return a.data.featured ? -1 : 1;
  return b.data.date.valueOf() - a.data.date.valueOf();
});
---
<BaseLayout
  title="Projects — Portfolio"
  description="ML, robotics, and systems engineering projects."
>
  <div class="max-w-[720px] mx-auto px-6 py-16">

    <SectionHero
      section="projects"
      title="Projects"
      description="Work that pushed my thinking forward. Building systems at the edge of what's possible: vision on limited hardware, model optimization, end-to-end deployment."
    />

    {sorted.map(project => (
      <ProjectCard
        title={project.data.title}
        slug={project.slug}
        summary={project.data.summary}
        date={project.data.date}
        techStack={project.data.techStack}
        featured={project.data.featured}
        stat={project.data.stat}
        domainTag={project.data.domainTag}
        cardDescription={project.data.cardDescription}
        github={project.data.links?.github}
      />
    ))}

  </div>
</BaseLayout>
