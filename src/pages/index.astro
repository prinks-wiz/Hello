---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import OrbitDivider from '../components/OrbitDivider.astro';
import MissionBlock from '../components/MissionBlock.astro';
import { getCollection } from 'astro:content';
import { url } from '../utils/url';

const [allProjects, allWriting] = await Promise.all([
  getCollection('projects'),
  getCollection('writing'),
]);

type RecentItem = {
  date: Date;
  title: string;
  href: string;
  kind: 'project' | 'post';
};

const recent: RecentItem[] = [
  ...allProjects.map(p => ({
    date:  p.data.date,
    title: p.data.title,
    href:  `/projects/${p.slug}`,
    kind:  'project' as const,
  })),
  ...allWriting.map(w => ({
    date:  w.data.date,
    title: w.data.title,
    href:  `/writing/${w.slug}`,
    kind:  'post' as const,
  })),
]
  .sort((a, b) => b.date.valueOf() - a.date.valueOf())
  .slice(0, 3);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
---
<BaseLayout title="Priyanka Vijaybaskar — Edge ML / Robotics">

  <div class="max-w-[720px] mx-auto px-6 py-20">

    <!-- ── Hero ─────────────────────────────────────────────────────────── -->
    <section aria-labelledby="bio-heading" class="mb-20">

      <p class="font-mono text-xs text-subtle tracking-[0.12em] mb-6 uppercase">
        MCDS @ Carnegie Mellon · Edge ML · Computer Vision
      </p>

      <!--
        Typing animation wrapper.
        The name text is invisible by default (opacity-0). The script
        below reveals characters one by one into #typed-name, keeping
        #name-ghost (the full text) visible but transparent so the line
        height is reserved from the start — no layout shift.
      -->
      <div class="relative mb-3" aria-labelledby="bio-heading">
        <!-- Ghost: holds the full-width layout, never seen by the eye -->
        <h1
          id="bio-heading"
          class="text-5xl font-bold text-content tracking-tight leading-none uppercase opacity-0 select-none"
          aria-hidden="true"
        >
          PRIYANKA VIJAYBASKAR
        </h1>
        <!-- Typed overlay: absolutely positioned on top of the ghost -->
        <h1
          id="typed-name"
          class="text-5xl font-bold text-content tracking-tight leading-none uppercase absolute inset-0"
          aria-label="Priyanka Vijaybaskar"
        >
          <!-- Characters injected by script -->
        </h1>
      </div>

      <!-- Callsign — initially hidden, fades in after typing completes -->
      <p
        id="callsign-line"
        class="font-mono text-sm text-subtle mb-10 opacity-0 transition-opacity duration-200"
        style="will-change: opacity;"
      >
        └── CALLSIGN:&nbsp;<a
          href="https://github.com/prinks-wiz"
          class="text-subtle hover:text-accent transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >prinks-wiz</a>
      </p>

      <!-- ── Bio — three rhythmically distinct lines ─────────────────── -->
      <div class="max-w-[600px] flex flex-col">
        <!-- Line 1: punchy statement -->
        <p class="text-2xl font-medium text-content tracking-tight">
          I shrink vision models until they fit on satellites.
        </p>

        <!-- Line 2: clinical metadata strip -->
        <p class="font-mono text-base text-subtle uppercase mt-6">
          CMU MCDS · Spacecraft Lab · graduating December 2026.
        </p>

        <!-- Line 3: flowing explanation -->
        <p class="text-lg text-subtle leading-relaxed mt-8">
          Currently building a deployment toolkit for vision-language models
          on edge hardware — because debugging ONNX exports the hard way
          got old fast.
        </p>
      </div>

      <!-- Quick nav links -->
      <div class="flex flex-wrap gap-x-6 gap-y-2 mt-10">
        <a href={url('/work')}     class="font-mono text-xs text-accent hover:underline">Work →</a>
        <a href={url('/projects')} class="font-mono text-xs text-accent hover:underline">Projects →</a>
        <a href={url('/writing')}  class="font-mono text-xs text-accent hover:underline">Writing →</a>
        <a href={url('/about')}    class="font-mono text-xs text-accent hover:underline">About →</a>
      </div>
    </section>

    <!-- Mission status block -->
    <MissionBlock />

    <!-- ── Currently ──────────────────────────────────────────────────── -->
    <section aria-labelledby="currently-heading" class="mb-16 mt-2">
      <SectionHeader number="01" title="CURRENTLY" />
      <h2 id="currently-heading" class="sr-only">Currently</h2>

      <ul class="space-y-3 list-none m-0 p-0">
        <li class="flex gap-3 text-sm">
          <span class="font-mono text-subtle shrink-0 mt-0.5">—</span>
          <span class="text-subtle leading-relaxed">
            Deploying quantized EfficientNet on Jetson Orin NX for on-orbit
            land-cover classification under sub-10W power constraints.
          </span>
        </li>
        <li class="flex gap-3 text-sm">
          <span class="font-mono text-subtle shrink-0 mt-0.5">—</span>
          <span class="text-subtle leading-relaxed">
            Building an open-source toolkit for exporting and running
            vision-language models on edge hardware via ONNX and TensorRT.
          </span>
        </li>
        <li class="flex gap-3 text-sm">
          <span class="font-mono text-subtle shrink-0 mt-0.5">—</span>
          <span class="text-subtle leading-relaxed">
            Reading: operator fusion strategies for transformer inference on
            ARM Mali GPUs.
          </span>
        </li>
      </ul>
    </section>

    <!-- Orbital divider -->
    <OrbitDivider />

    <!-- ── Recent ────────────────────────────────────────────────────── -->
    {recent.length > 0 && (
      <section aria-labelledby="recent-heading" class="mt-2">
        <SectionHeader number="02" title="RECENT" />
        <h2 id="recent-heading" class="sr-only">Recent projects and writing</h2>

        <ul class="list-none m-0 p-0">
          {recent.map(item => (
            <li class="border-b border-edge py-5">
              <div class="flex items-baseline justify-between gap-4">
                <a
                  href={item.href}
                  class="text-sm font-medium text-content hover:text-accent transition-colors flex-1 min-w-0"
                >
                  {item.title}
                </a>
                <div class="flex items-center gap-3 shrink-0">
                  <span class="font-mono text-xs text-subtle border border-edge px-1.5 py-0.5">
                    {item.kind}
                  </span>
                  <time
                    class="font-mono text-xs text-subtle"
                    datetime={item.date.toISOString()}
                  >
                    {fmtDate(item.date)}
                  </time>
                </div>
              </div>
            </li>
          ))}
        </ul>

        <div class="pt-6 flex gap-6">
          <a href={url('/projects')} class="font-mono text-xs text-subtle hover:text-accent transition-colors">
            All projects →
          </a>
          <a href={url('/writing')} class="font-mono text-xs text-subtle hover:text-accent transition-colors">
            All writing →
          </a>
        </div>
      </section>
    )}

  </div>
</BaseLayout>

<script>
  const FULL_TEXT  = 'PRIYANKA VIJAYBASKAR';
  const CHAR_DELAY = 45; // ms per character
  const FLASH_MS   = 550; // name flash duration before cursor appears

  const target   = document.getElementById('typed-name')    as HTMLElement | null;
  const callsign = document.getElementById('callsign-line') as HTMLElement | null;

  if (!target || !callsign) throw new Error('Typing animation targets not found');

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    // Skip entirely — show static name + blinking cursor immediately
    target.textContent = FULL_TEXT;
    const cur = document.createElement('span');
    cur.className = 'term-cursor';
    cur.textContent = '▮';
    target.appendChild(cur);
    callsign.style.opacity = '1';
  } else {
    let idx = 0;

    function typeNext() {
      if (idx < FULL_TEXT.length) {
        // During typing: embed cursor char directly in text for simplicity
        target.textContent = FULL_TEXT.slice(0, idx + 1) + '▮';
        idx++;
        setTimeout(typeNext, CHAR_DELAY);
      } else {
        // Typing done — clear text, trigger ONE name flash
        target.textContent = FULL_TEXT;
        target.classList.add('name-flash');

        setTimeout(() => {
          target.classList.remove('name-flash');

          // Append a permanently blinking terminal cursor
          const cur = document.createElement('span');
          cur.className = 'term-cursor';
          cur.textContent = '▮';
          target.appendChild(cur);

          // Reveal callsign
          callsign.style.opacity = '1';
        }, FLASH_MS);
      }
    }

    setTimeout(typeNext, 200);
  }
</script>

<style>
  /* One-shot flash: name goes dark then snaps back */
  @keyframes name-flash {
    0%   { opacity: 1; }
    20%  { opacity: 0; }
    65%  { opacity: 0; }
    100% { opacity: 1; }
  }
  .name-flash { animation: name-flash 0.55s ease forwards; }

  /* Permanent terminal cursor — blinks indefinitely */
  @keyframes term-blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }
  .term-cursor {
    animation: term-blink 1s step-start infinite;
    margin-left: 2px;
  }
</style>
