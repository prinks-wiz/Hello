---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { url } from '../utils/url';

const [allProjects, allWriting] = await Promise.all([
  getCollection('projects'),
  getCollection('writing'),
]);

const projects = allProjects.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return b.data.date.valueOf() - a.data.date.valueOf();
});

const writing = allWriting.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
---
<BaseLayout title="Priyanka Vijaybaskar — Perception Engineer">

  <!-- ── HERO ──────────────────────────────────────────────────────────────── -->
  <section class="hero-section" aria-labelledby="bio-heading">
    <div class="hero-text">
        <p class="font-mono text-xs tracking-[0.12em] uppercase mb-5" style="color: var(--text-muted)">
          MCDS @ Carnegie Mellon · Edge ML · Computer Vision
        </p>

        <div class="relative mb-2" aria-labelledby="bio-heading">
          <h1
            id="bio-heading"
            class="text-4xl sm:text-5xl font-bold tracking-tight leading-none uppercase opacity-0 select-none"
            style="color: var(--text)"
            aria-hidden="true"
          >PRIYANKA VIJAYBASKAR</h1>
          <h1
            id="typed-name"
            class="text-4xl sm:text-5xl font-bold tracking-tight leading-none uppercase absolute inset-0"
            style="color: var(--text)"
            aria-label="Priyanka Vijaybaskar"
          ></h1>
        </div>

        <p
          id="callsign-line"
          class="font-mono text-sm mb-8 opacity-0 transition-opacity duration-200"
          style="color: var(--text-muted); will-change: opacity"
        >
          └── CALLSIGN:&nbsp;<a
            href="https://github.com/prinks-wiz"
            class="hover:text-accent transition-colors"
            style="color: var(--text-muted)"
            target="_blank"
            rel="noopener noreferrer"
          >prinks-wiz</a>
        </p>

        <p class="text-xl font-medium italic mb-6 leading-snug" style="color: var(--text-muted)">
          I train vision models in the cloud and make them run on hardware in orbit.
        </p>

        <p class="font-mono text-sm uppercase mb-8" style="color: var(--text-muted)">
          CMU MCDS · Spacecraft Lab · graduating December 2026.
        </p>

        <a
          href={url('/resume.pdf')}
          target="_blank"
          rel="noopener noreferrer"
          class="resume-btn font-mono text-xs px-4 py-2 border transition-colors"
          style="color: var(--accent); border-color: var(--accent);"
        >↓ Download Résumé</a>
    </div>
  </section>

  <div class="content-col">

    <!-- ── THE PROBLEM ──────────────────────────────────────────────────────── -->
    <section id="the-problem" class="chapter" aria-labelledby="problem-heading">
      <p class="kicker">The Problem</p>
      <h2 id="problem-heading" class="chapter-headline">
        A camera 500 km up has to figure out where it might be.
      </h2>
      <p class="chapter-body">
        I work on Argus, a small satellite built at CMU. My job is the vision side:
        helping it figure out where it is from what its camera sees.
        That problem — onboard navigation from imagery, without GPS, on a power budget
        measured in watts — is harder than it sounds, and more interesting.
      </p>
    </section>

    <!-- ── CURRENTLY ────────────────────────────────────────────────────────── -->
    <section id="currently" class="chapter" aria-labelledby="currently-heading">
      <p class="kicker">Currently</p>
      <h2 id="currently-heading" class="chapter-headline">
        Two projects running, one deadline looming.
      </h2>
      <ol class="step-list" aria-label="Current projects">
        <li>
          <span class="step-num">01</span>
          <div>
            <p class="step-title">Vision for Argus</p>
            <p class="step-body">
              Summer research — building the onboard navigation pipeline for a CubeSat
              at the CMU Spacecraft Lab.
            </p>
          </div>
        </li>
        <li>
          <span class="step-num">02</span>
          <div>
            <p class="step-title">Capstone: VLMs for autonomous vehicles</p>
            <p class="step-body">
              Investigating where vision-language models break — and what that means
              for deploying them in safety-critical systems.
            </p>
          </div>
        </li>
        <li>
          <span class="step-num">03</span>
          <div>
            <p class="step-title">MCDS @ Carnegie Mellon</p>
            <p class="step-body">Graduating December 2026. Looking for full-time roles starting early 2027.</p>
          </div>
        </li>
      </ol>
    </section>

    <!-- ── PROJECTS ─────────────────────────────────────────────────────────── -->
    <section id="projects" class="chapter" aria-labelledby="projects-heading">
      <p class="kicker">Projects</p>
      <h2 id="projects-heading" class="chapter-headline">
        Things built, broken, and eventually working.
      </h2>
      <div class="projects-grid">
        {projects.map(p => (
          <ProjectCard
            title={p.data.title}
            slug={p.slug}
            summary={p.data.summary}
            date={p.data.date}
            techStack={p.data.techStack}
            featured={p.data.featured}
            stat={p.data.stat}
            domainTag={p.data.domainTag}
            cardDescription={p.data.cardDescription}
            github={p.data.links?.github}
          />
        ))}
      </div>
      <p class="see-all">
        <a href="/projects">All projects →</a>
      </p>
    </section>

    <!-- ── WRITING ──────────────────────────────────────────────────────────── -->
    <section id="writing" class="chapter" aria-labelledby="writing-heading">
      <p class="kicker">Writing</p>
      <h2 id="writing-heading" class="chapter-headline">
        Notes from the work.
      </h2>
      <ul class="writing-log" aria-label="Writing posts">
        {writing.map(w => (
          <li>
            <a href={`/writing/${w.slug}`} class="writing-entry">
              <time class="entry-date font-mono" datetime={w.data.date.toISOString()}>
                {fmtDate(w.data.date)}
              </time>
              <span class="entry-title">{w.data.title}</span>
              {w.data.category === 'personal' && (
                <span class="entry-tag">personal</span>
              )}
            </a>
          </li>
        ))}
      </ul>
      <p class="see-all">
        <a href="/writing">All writing →</a>
      </p>
    </section>

    <!-- ── ABOUT ────────────────────────────────────────────────────────────── -->
    <section id="about" class="chapter" aria-labelledby="about-heading">
      <p class="kicker">About</p>
      <h2 id="about-heading" class="chapter-headline">
        On the gap between the lab and the real world.
      </h2>
      <p class="chapter-body">
        I'm an engineer who cares about the moment when "it works in the lab" has to
        become "it works on a spacecraft in orbit, at 5W, without a patch." The constraint
        is the interesting part. I'm open to full-time perception engineering roles starting
        early 2027 — robotics, aerospace, edge AI, anywhere the hardware pushes back.
      </p>
      <p class="chapter-body" style="margin-top: 1rem">
        I also read poetry.
      </p>
      <p class="see-all" style="margin-top: 1.5rem">
        <a href="/about">Full story →</a>
      </p>
    </section>

    <!-- ── CTA BAND ─────────────────────────────────────────────────────────── -->
    <div class="cta-band" role="contentinfo" aria-label="Contact links">
      <a href="mailto:pvijayba@andrew.cmu.edu" class="cta-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="20" height="16" x="2" y="4" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        Email
      </a>
      <a href="https://github.com/prinks-wiz" target="_blank" rel="noopener noreferrer" class="cta-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65S9 17.44 9 18v4"/>
          <path d="M9 18c-4.51 2-5-2-7-2"/>
        </svg>
        GitHub
      </a>
      <a href="https://www.linkedin.com/in/priyankavijaybaskar" target="_blank" rel="noopener noreferrer" class="cta-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
          <rect width="4" height="12" x="2" y="9"/>
          <circle cx="4" cy="4" r="2"/>
        </svg>
        LinkedIn
      </a>
    </div>

  </div><!-- /content-col -->

</BaseLayout>

<!-- Typing animation script -->
<script>
  const FULL_TEXT  = 'PRIYANKA VIJAYBASKAR';
  const CHAR_DELAY = 45;
  const FLASH_MS   = 550;

  const target   = document.getElementById('typed-name')    as HTMLElement | null;
  const callsign = document.getElementById('callsign-line') as HTMLElement | null;
  if (!target || !callsign) throw new Error('Typing targets not found');

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    target.textContent = FULL_TEXT;
    const cur = document.createElement('span');
    cur.className = 'term-cursor';
    cur.textContent = '▮';
    target.appendChild(cur);
    callsign.style.opacity = '1';
  } else {
    let idx = 0;
    function typeNext() {
      if (idx < FULL_TEXT.length) {
        target!.textContent = FULL_TEXT.slice(0, idx + 1) + '▮';
        idx++;
        setTimeout(typeNext, CHAR_DELAY);
      } else {
        target!.textContent = FULL_TEXT;
        target!.classList.add('name-flash');
        setTimeout(() => {
          target!.classList.remove('name-flash');
          const cur = document.createElement('span');
          cur.className = 'term-cursor';
          cur.textContent = '▮';
          target!.appendChild(cur);
          callsign!.style.opacity = '1';
        }, FLASH_MS);
      }
    }
    setTimeout(typeNext, 200);
  }
</script>

<style>
  /* ── Hero layout ─────────────────────────────────────────────────────────── */
  .hero-section {
    width: 100%;
    padding: 4rem 1.5rem 2rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .hero-text {
    min-width: 0;
  }

  @media (max-width: 767px) {
    .hero-section {
      padding: 2.5rem 1.5rem 1.5rem;
    }
  }

  .resume-btn:hover {
    background-color: var(--accent);
    color: #fff !important;
  }

  /* ── Narrow content column ───────────────────────────────────────────────── */
  .content-col {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Chapter sections ─────────────────────────────────────────────────────── */
  .chapter {
    padding: 5rem 0 2rem;
    border-top: 1px solid var(--border);
    margin-top: 2rem;
  }

  .chapter:first-child {
    border-top: none;
  }

  .kicker {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.875rem;
  }

  .chapter-headline {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 1.5rem;
    max-width: 580px;
  }

  .chapter-body {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--text-muted);
    max-width: 600px;
  }

  /* ── Numbered steps ──────────────────────────────────────────────────────── */
  .step-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .step-list li {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .step-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.05em;
    flex-shrink: 0;
    margin-top: 0.25rem;
    min-width: 1.75rem;
  }

  .step-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .step-body {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  /* ── Projects grid ──────────────────────────────────────────────────────── */
  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── Writing log ─────────────────────────────────────────────────────────── */
  .writing-log {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .writing-entry {
    display: grid;
    grid-template-columns: 5.5rem 1fr auto;
    align-items: baseline;
    gap: 1.25rem;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: color 0.15s;
  }

  .writing-entry:hover .entry-title {
    color: var(--accent);
  }

  .entry-date {
    font-size: 0.75rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .entry-title {
    font-size: 0.9375rem;
    color: var(--text);
    transition: color 0.15s;
  }

  .entry-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    padding: 0.125rem 0.5rem;
    border: 1px solid var(--border);
    color: var(--text-muted);
    white-space: nowrap;
    text-transform: uppercase;
  }

  /* ── See all link ─────────────────────────────────────────────────────────── */
  .see-all {
    margin-top: 1.5rem;
  }
  .see-all a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .see-all a:hover {
    color: var(--accent);
  }

  /* ── CTA band ─────────────────────────────────────────────────────────────── */
  .cta-band {
    display: flex;
    gap: 2rem;
    padding: 3.5rem 0 2rem;
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    flex-wrap: wrap;
  }

  .cta-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .cta-link:hover {
    color: var(--accent);
  }

  /* ── Typing animation ──────────────────────────────────────────────────────── */
  @keyframes name-flash {
    0%   { opacity: 1; }
    20%  { opacity: 0; }
    65%  { opacity: 0; }
    100% { opacity: 1; }
  }
  .name-flash { animation: name-flash 0.55s ease forwards; }

  @keyframes term-blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }
  .term-cursor {
    animation: term-blink 1s step-start infinite;
    margin-left: 2px;
  }
</style>
