---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHero from '../components/SectionHero.astro';
import { url } from '../utils/url';
---
<BaseLayout
  title="About — Priyanka Vijaybaskar"
  description="MCDS student at CMU building perception systems for spacecraft and robots."
>
  <div class="max-w-[720px] mx-auto px-6 py-16">

    <SectionHero
      section="about"
      title="About"
      description="Building things that work under pressure. Spacecraft, robots, models at the edge — systems that fail in clear ways."
    />

    <!-- ── Identity block: photo + name ────────────────────────────────── -->
    <div class="flex items-start gap-6 mb-12">
      <img
        src="/Website_Profile.jpeg"
        alt="Priyanka Vijaybaskar"
        width="96"
        height="96"
        class="rounded-sm object-cover shrink-0"
        style="width: 96px; height: 96px;"
        loading="eager"
      />
      <div>
        <h1 class="text-2xl font-semibold text-content tracking-tight mb-1">
          Priyanka Vijaybaskar
        </h1>
        <p class="font-mono text-xs text-subtle uppercase tracking-[0.12em]">
          MCDS @ Carnegie Mellon · Edge ML · Spacecraft Lab
        </p>
      </div>
    </div>

    <!-- ── Background ──────────────────────────────────────────────────── -->
    <section aria-labelledby="background-heading" class="mb-12">
      <h2
        id="background-heading"
        class="font-mono text-xs text-subtle uppercase tracking-[0.15em] mb-5"
      >
        Background
      </h2>
      <div class="space-y-4 text-subtle leading-relaxed text-sm">
        <p>
          I am an MCDS student at Carnegie Mellon working at the intersection of machine
          learning and physical systems. My current research is at the CMU Spacecraft Lab,
          where I am building the computer vision pipeline for the Argus mission — helping a
          satellite figure out where it is from what its camera sees. I am also building an
          open-source toolkit for deploying vision-language models on edge hardware via ONNX
          and TensorRT, because the export pipeline has a talent for breaking in interesting
          ways and nobody has fixed it properly yet.
        </p>
        <p>
          What draws me to this space is the constraint. A cloud model can be re-evaluated,
          patched, and scaled overnight. A model running on a spacecraft in low Earth orbit,
          or on a legged robot mid-traverse, cannot. That gap between "it works in the lab"
          and "it works reliably on hardware, at power, in the real world" is where I want
          to spend my career. I am particularly interested in perception roles at companies
          where the physical environment is the test: robotics, aerospace, edge AI. I am
          graduating in December 2026 and am open to full-time roles starting early 2027.
        </p>
        <p>
          I also read poetry.
        </p>
      </div>
    </section>

    <!-- ── CV / Résumé ────────────────────────────────────────────────── -->
    <section
      aria-labelledby="cv-heading"
      class="mb-12 border-t border-edge pt-8"
    >
      <h2
        id="cv-heading"
        class="font-mono text-xs text-subtle uppercase tracking-[0.15em] mb-5"
      >
        Résumé
      </h2>
      <a
        href={url('/resume.pdf')}
        class="inline-block font-mono text-sm px-4 py-2 border transition-colors hover:text-white"
        style="color: var(--accent); border-color: var(--accent);"
        onmouseover="this.style.backgroundColor='var(--accent)'"
        onmouseout="this.style.backgroundColor='transparent'"
        target="_blank"
        rel="noopener noreferrer"
      >
        ↓ Download Résumé
      </a>
    </section>

    <!-- ── Contact ────────────────────────────────────────────────────── -->
    <section
      aria-labelledby="contact-heading"
      class="border-t border-edge pt-8"
    >
      <h2
        id="contact-heading"
        class="font-mono text-xs text-subtle uppercase tracking-[0.15em] mb-5"
      >
        Contact
      </h2>
      <ul class="space-y-3 list-none m-0 p-0">
        <li>
          <a
            href="mailto:pvijayba@andrew.cmu.edu"
            class="flex items-center gap-2 font-mono text-sm text-accent hover:underline"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            pvijayba@andrew.cmu.edu
          </a>
        </li>
        <li>
          <a
            href="https://github.com/prinks-wiz"
            class="flex items-center gap-2 font-mono text-sm text-accent hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65S9 17.44 9 18v4"/>
              <path d="M9 18c-4.51 2-5-2-7-2"/>
            </svg>
            github.com/prinks-wiz
          </a>
        </li>
        <li>
          <a
            href="https://www.linkedin.com/in/priyankavijaybaskar"
            class="flex items-center gap-2 font-mono text-sm text-accent hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect width="4" height="12" x="2" y="9"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
            linkedin.com/in/priyankavijaybaskar
          </a>
        </li>
      </ul>
    </section>

  </div>
</BaseLayout>
