---
interface Props {
  section: 'work' | 'projects' | 'writing' | 'about';
  title: string;
  description?: string;
}

const { section, title, description } = Astro.props;

const config = {
  work: { icon: '✦', color: 'var(--work-accent)', planet: 'The Forge' },
  projects: { icon: '◯', color: 'var(--projects-accent)', planet: 'The Workshop' },
  writing: { icon: '◇', color: 'var(--writing-accent)', planet: 'The Library' },
  about: { icon: '★', color: 'var(--about-accent)', planet: 'The Heart' },
};

const { icon, color, planet } = config[section];
---
<style>
  .section-hero {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .planet-icon {
    font-size: 2rem;
    line-height: 1;
    margin-bottom: 0.5rem;
    display: inline-block;
  }

  .title {
    font-size: 1.875rem;
    font-weight: 600;
    margin: 0.5rem 0 0.25rem;
    color: var(--text);
  }

  .planet-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .description {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 600px;
  }
</style>

<div class="section-hero">
  <div class="planet-icon" style={`color: ${color}`}>
    {icon}
  </div>
  <h1 class="title">{title}</h1>
  <div class="planet-label" style={`color: ${color}`}>
    {planet}
  </div>
  {description && <p class="description">{description}</p>}
</div>
