---
import OrbitalSimulation from './OrbitalSimulation.astro';

const year = new Date().getFullYear();
---
<footer class="border-t border-edge mt-24">

  <!-- Orbital simulation — centered, clearly labelled physics -->
  <OrbitalSimulation />

  <div class="max-w-[720px] mx-auto px-6 py-8 flex items-center justify-between">
    <span class="font-mono text-xs text-subtle">© {year}</span>
    <div class="flex items-center gap-5">
      <a
        href="https://github.com/prinks-wiz"
        class="flex items-center gap-1.5 font-mono text-xs text-subtle hover:text-accent transition-colors"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65S9 17.44 9 18v4"/>
          <path d="M9 18c-4.51 2-5-2-7-2"/>
        </svg>
        GitHub
      </a>
      <a
        href="https://www.linkedin.com/in/priyankavijaybaskar"
        class="flex items-center gap-1.5 font-mono text-xs text-subtle hover:text-accent transition-colors"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
          <rect width="4" height="12" x="2" y="9"/>
          <circle cx="4" cy="4" r="2"/>
        </svg>
        LinkedIn
      </a>
      <a
        href="mailto:pvijayba@andrew.cmu.edu"
        class="flex items-center gap-1.5 font-mono text-xs text-subtle hover:text-accent transition-colors"
        aria-label="Email"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="20" height="16" x="2" y="4" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        pvijayba@andrew.cmu.edu
      </a>
    </div>
  </div>
</footer>
