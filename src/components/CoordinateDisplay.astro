---
// Default: Pittsburgh, PA. Overwritten client-side via Geolocation API.
---
<!--
  CoordinateDisplay: shows the visitor's actual GPS coordinates.
  Falls back to Pittsburgh (40.4406, -79.9959) if permission denied or unavailable.
  Two-line layout aligns LAT / LON labels and values in a fixed grid.
-->
<span
  id="coord-display"
  class="font-mono text-xs text-subtle"
  style="font-variant-numeric: tabular-nums; letter-spacing: 0.06em; line-height: 1.5;"
  aria-live="polite"
  aria-label="Visitor location coordinates"
>
  <span class="flex flex-col">
    <span><span class="inline-block w-8">LAT</span> <span id="coord-lat">40.4406</span></span>
    <span><span class="inline-block w-8">LON</span> <span id="coord-lon">-79.9959</span></span>
  </span>
</span>

<script>
  const latEl = document.getElementById('coord-lat');
  const lonEl = document.getElementById('coord-lon');

  if (latEl && lonEl && 'geolocation' in navigator) {
    const cached = sessionStorage.getItem('coords');
    if (cached) {
      const { lat, lon } = JSON.parse(cached);
      latEl.textContent = lat;
      lonEl.textContent = lon;
    } else {
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          const lat = pos.coords.latitude.toFixed(4);
          const lon = pos.coords.longitude.toFixed(4);
          latEl.textContent = lat;
          lonEl.textContent = lon;
          try { sessionStorage.setItem('coords', JSON.stringify({ lat, lon })); } catch (_) {}
        },
        () => { /* permission denied — keep Pittsburgh default */ },
        { timeout: 5000, maximumAge: 300_000 }
      );
    }
  }
</script>
