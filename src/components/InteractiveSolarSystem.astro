---
/*
  InteractiveSolarSystem — clickable hero navigation
  4 planets orbit a central star, each leading to a main section.
  SVG-based with CSS animations and client-side navigation.
*/
const sections = [
  { id: 'work',     label: 'The Forge',     href: '/work',     icon: '✦', color: '#d4522f' },
  { id: 'projects', label: 'The Workshop',  href: '/projects', icon: '◯', color: '#3b82f6' },
  { id: 'writing',  label: 'The Library',   href: '/writing',  icon: '◇', color: '#a78bfa' },
  { id: 'about',    label: 'The Heart',     href: '/about',    icon: '★', color: '#fbbf24' },
];
---
<style>
  :root {
    --work-accent: #d4522f;
    --projects-accent: #3b82f6;
    --writing-accent: #a78bfa;
    --about-accent: #fbbf24;
  }

  .system-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: radial-gradient(circle at 50% 50%, rgba(31, 41, 55, 0.3), rgba(0, 0, 0, 0.6));
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    min-height: 500px;
    max-height: 600px;
    border-radius: 2px;
    margin-bottom: 2rem;
  }

  .dark .system-container {
    background: radial-gradient(circle at 50% 50%, rgba(20, 20, 25, 0.5), rgba(0, 0, 0, 0.8));
  }

  svg {
    width: 100%;
    height: 100%;
    position: absolute;
    inset: 0;
  }

  .central-star {
    fill: var(--accent);
    filter: drop-shadow(0 0 20px var(--accent));
  }

  .orbit {
    fill: none;
    stroke: var(--text-muted);
    stroke-width: 0.5;
    opacity: 0.3;
  }

  .planet-group {
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .planet-group:hover circle {
    filter: drop-shadow(0 0 15px currentColor);
  }

  .planet-group:hover text {
    opacity: 1;
  }

  .planet-circle {
    transition: r 0.3s ease;
  }

  .planet-group:hover .planet-circle {
    r: 7;
  }

  .planet-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    text-anchor: middle;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .planet-label {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    text-anchor: middle;
    opacity: 0;
    transition: opacity 0.3s ease;
    font-weight: 500;
  }

  .planet-group:hover .planet-label {
    opacity: 1;
  }

  /* Keyboard focus ring */
  .planet-group:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Reduced motion: static, no orbit animation */
  @media (prefers-reduced-motion: reduce) {
    .system-container {
      min-height: 300px;
      max-height: 400px;
    }
    svg {
      filter: grayscale(20%);
    }
  }

  /* Mobile: smaller container, simpler layout */
  @media (max-width: 640px) {
    .system-container {
      aspect-ratio: 4 / 3;
      min-height: 300px;
      max-height: 400px;
    }

    .planet-text {
      font-size: 9px;
    }

    .planet-label {
      font-size: 11px;
    }
  }
</style>

<div class="system-container" role="navigation" aria-label="Main sections navigation">
  <svg viewBox="0 0 800 450" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
    <!-- Central star -->
    <circle class="central-star" cx="400" cy="225" r="6" />

    <!-- Orbit paths -->
    <ellipse class="orbit" cx="400" cy="225" rx="120" ry="80" />
    <ellipse class="orbit" cx="400" cy="225" rx="200" ry="110" />
    <ellipse class="orbit" cx="400" cy="225" rx="270" ry="140" />
    <ellipse class="orbit" cx="400" cy="225" rx="320" ry="160" />

    <!-- Planet 1: Work (left, inner orbit) -->
    <g class="planet-group" role="button" tabindex="0" data-href="/work" aria-label="The Forge - Work section">
      <circle class="planet-circle" cx="280" cy="225" r="5" fill="var(--work-accent)" />
      <text class="planet-text" x="280" y="245">✦</text>
      <text class="planet-label" x="280" y="260">The Forge</text>
    </g>

    <!-- Planet 2: Projects (right, middle orbit) -->
    <g class="planet-group" role="button" tabindex="0" data-href="/projects" aria-label="The Workshop - Projects section">
      <circle class="planet-circle" cx="600" cy="225" r="5" fill="var(--projects-accent)" />
      <text class="planet-text" x="600" y="245">◯</text>
      <text class="planet-label" x="600" y="260">The Workshop</text>
    </g>

    <!-- Planet 3: Writing (top, outer orbit) -->
    <g class="planet-group" role="button" tabindex="0" data-href="/writing" aria-label="The Library - Writing section">
      <circle class="planet-circle" cx="400" cy="65" r="5" fill="var(--writing-accent)" />
      <text class="planet-text" x="400" y="50">◇</text>
      <text class="planet-label" x="400" y="35">The Library</text>
    </g>

    <!-- Planet 4: About (bottom, far outer orbit) -->
    <g class="planet-group" role="button" tabindex="0" data-href="/about" aria-label="The Heart - About section">
      <circle class="planet-circle" cx="400" cy="385" r="5" fill="var(--about-accent)" />
      <text class="planet-text" x="400" y="410">★</text>
      <text class="planet-label" x="400" y="425">The Heart</text>
    </g>
  </svg>
</div>

<script>
  // Click navigation
  document.querySelectorAll('.planet-group').forEach(planet => {
    planet.addEventListener('click', () => {
      const href = planet.getAttribute('data-href');
      if (href) window.location.href = href;
    });

    // Keyboard: Enter key navigation
    planet.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        const href = planet.getAttribute('data-href');
        if (href) window.location.href = href;
      }
    });
  });
</script>
