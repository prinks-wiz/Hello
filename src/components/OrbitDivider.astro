<!--
  Decorative orbital-path divider. Draws a sine-like dashed curve with a
  single "satellite" dot at the 30% horizontal mark. Purely presentational.

  Path math: cubic bezier M 0 50 C 200 15, 400 65, 600 35 C 800 5, 900 55, 1000 40
  Satellite at 30% horizontal = x≈300. At t=0.5 of the first bezier segment,
  x=300 and y≈41 — close enough for a decorative element.
-->
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 1000 80"
  width="100%"
  height="80"
  role="presentation"
  aria-hidden="true"
  class="block w-full overflow-visible"
>
  <!-- Orbital trajectory path -->
  <path
    d="M 0 50 C 200 15, 400 65, 600 35 C 800 5, 900 55, 1000 40"
    fill="none"
    stroke="var(--border)"
    stroke-width="1"
    stroke-dasharray="4 4"
    stroke-linecap="round"
  />

  <!-- Satellite — placed at x≈300, y≈41 (30% horizontal mark) -->
  <circle
    cx="300"
    cy="41"
    r="3"
    fill="var(--accent)"
  />
</svg>
