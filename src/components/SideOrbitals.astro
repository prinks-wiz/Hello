<!--
  SideOrbitals — three canvas physics simulations in the side margins.
  · Planet-Moon:   hierarchical Keplerian orbits (left, upper)
  · Binary Stars:  two-body system around common barycenter (right, middle)
  · Black Hole:    event horizon + accretion disk + gravitational lensing rays (left, lower)

  Each canvas uses real physics (Newton-Raphson Kepler solver) or principled
  approximations. Hidden below 1100px where side margins are too narrow.
  Reduced-motion: static single frame, no rAF loop.
-->
<style>
  :root { --so-op: 0.90; }
  .dark { --so-op: 1.0; }

  .so-wrap {
    position: fixed;
    width: 15vw;
    pointer-events: none;
    z-index: 1; /* above star SVGs */
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  #so-pm { left: 0;  top: 16vh; }
  #so-bs { right: 0; top: 38vh; }
  #so-bh { left: 0;  top: 60vh; }

  @media (max-width: 1100px) { .so-wrap { display: none; } }

  .so-canvas {
    display: block;
    opacity: var(--so-op);
  }
  .so-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 6.5px;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    opacity: 0.7;
    white-space: nowrap;
    text-align: center;
  }
</style>

<!-- Planet-Moon: left panel, upper -->
<div class="so-wrap" id="so-pm" aria-hidden="true">
  <canvas id="canvas-pm" class="so-canvas"
    aria-label="Planet-moon orbital simulation" role="img"></canvas>
  <span class="so-label">PLANET-MOON</span>
</div>

<!-- Binary Stars: right panel, middle -->
<div class="so-wrap" id="so-bs" aria-hidden="true">
  <canvas id="canvas-bs" class="so-canvas"
    aria-label="Binary star system simulation" role="img"></canvas>
  <span class="so-label">BINARY STARS</span>
</div>

<!-- Black Hole: left panel, lower -->
<div class="so-wrap" id="so-bh" aria-hidden="true">
  <canvas id="canvas-bh" class="so-canvas"
    aria-label="Black hole gravitational lensing simulation" role="img"></canvas>
  <span class="so-label">BLACK HOLE</span>
</div>

<script>
(function () {
  // ── Shared utilities ──────────────────────────────────────────────────────
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function cssVar(name: string): string {
    return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
  }

  // Robust hex → rgba (handles 3-char, 6-char, or rgb(...) strings gracefully)
  function rgba(color: string, a: number): string {
    const c = color.trim();
    if (c.startsWith('#')) {
      const full = c.length === 4
        ? '#' + c[1]+c[1]+c[2]+c[2]+c[3]+c[3]
        : c;
      const r = parseInt(full.slice(1,3), 16);
      const g = parseInt(full.slice(3,5), 16);
      const b = parseInt(full.slice(5,7), 16);
      return `rgba(${r},${g},${b},${a})`;
    }
    // Already rgb/rgba — swap the alpha
    return c.replace(/rgba?\(([^)]+)\)/, (_: string, inner: string) => {
      const parts = inner.split(',').slice(0, 3).join(',');
      return `rgba(${parts},${a})`;
    });
  }

  // Newton-Raphson Kepler equation solver (5 iterations)
  function solveKepler(M: number, e: number): number {
    let E = M;
    for (let i = 0; i < 5; i++) E -= (E - e * Math.sin(E) - M) / (1 - e * Math.cos(E));
    return E;
  }

  // Cartesian position from Keplerian elements; (cx,cy) = focus position
  function keplerPos(a: number, e: number, T: number, rot: number, t: number, cx: number, cy: number) {
    const M  = (2 * Math.PI * t) / T;
    const E  = solveKepler(M, e);
    const nu = 2 * Math.atan2(Math.sqrt(1 + e) * Math.sin(E / 2), Math.sqrt(1 - e) * Math.cos(E / 2));
    const r  = a * (1 - e * Math.cos(E));
    return { x: cx + r * Math.cos(nu + rot), y: cy + r * Math.sin(nu + rot) };
  }

  // Setup canvas with device pixel ratio scaling
  function setupCanvas(id: string, size: number) {
    const el = document.getElementById(id) as HTMLCanvasElement | null;
    if (!el) return null;
    const dpr = window.devicePixelRatio || 1;
    el.width  = Math.round(size * dpr);
    el.height = Math.round(size * dpr);
    el.style.width  = size + 'px';
    el.style.height = size + 'px';
    const ctx = el.getContext('2d')!;
    ctx.scale(dpr, dpr);
    return { ctx, S: size, CX: size / 2, CY: size / 2 };
  }

  // Fading trail renderer
  type Pt = { x: number; y: number };
  function drawTrail(ctx: CanvasRenderingContext2D, trail: Pt[], r: number, color: string) {
    for (let i = 1; i < trail.length; i++) {
      const alpha = (i / trail.length) * 0.65;
      ctx.beginPath();
      ctx.arc(trail[i].x, trail[i].y, r, 0, Math.PI * 2);
      ctx.fillStyle = rgba(color, alpha);
      ctx.fill();
    }
  }

  // Dashed orbit ellipse around focus
  function drawOrbitEllipse(
    ctx: CanvasRenderingContext2D,
    a: number, e: number, rot: number,
    focusX: number, focusY: number,
    color: string, alpha = 0.18
  ) {
    const b = a * Math.sqrt(1 - e * e);
    const c = a * e;
    ctx.save();
    ctx.translate(focusX - c * Math.cos(rot), focusY - c * Math.sin(rot));
    ctx.rotate(rot);
    ctx.beginPath();
    ctx.ellipse(0, 0, a, b, 0, 0, Math.PI * 2);
    ctx.strokeStyle = color;
    ctx.globalAlpha = alpha;
    ctx.lineWidth   = 0.6;
    ctx.setLineDash([2, 4]);
    ctx.stroke();
    ctx.restore();
    ctx.globalAlpha = 1;
    ctx.setLineDash([]);
  }

  // ── Canvas 1: Planet-Moon ─────────────────────────────────────────────────
  const pm = setupCanvas('canvas-pm', 120);
  const pmTrailPlanet: Pt[] = [];
  const pmTrailMoon:   Pt[] = [];

  function drawPM(t: number) {
    if (!pm) return;
    const { ctx, S, CX, CY } = pm;
    const text   = cssVar('--text')   || '#1a1a1a';
    const muted  = cssVar('--text-muted') || '#6b7280';
    const accent = cssVar('--accent') || '#1E40AF';

    ctx.clearRect(0, 0, S, S);

    // Central star — radial glow
    const sg = ctx.createRadialGradient(CX, CY, 0, CX, CY, 10);
    sg.addColorStop(0,    accent);
    sg.addColorStop(0.4,  rgba(accent, 0.45));
    sg.addColorStop(1,    rgba(accent, 0));
    ctx.beginPath(); ctx.arc(CX, CY, 10, 0, Math.PI * 2);
    ctx.fillStyle = sg; ctx.fill();
    ctx.beginPath(); ctx.arc(CX, CY, 3, 0, Math.PI * 2);
    ctx.fillStyle = accent; ctx.fill();

    // Planet orbit ellipse
    drawOrbitEllipse(ctx, 32, 0.13, 0, CX, CY, text);

    // Planet position + trail
    const planet = keplerPos(32, 0.13, 11, 0, t, CX, CY);
    if (!reduceMotion) {
      pmTrailPlanet.push({ ...planet });
      if (pmTrailPlanet.length > 28) pmTrailPlanet.shift();
      drawTrail(ctx, pmTrailPlanet, 1.2, text);
    }

    // Moon orbit ellipse (translates with planet)
    const mA = 12, mE = 0.06, mRot = Math.PI * 0.3;
    drawOrbitEllipse(ctx, mA, mE, mRot, planet.x, planet.y, muted, 0.22);

    // Moon position + trail
    const moonRel = keplerPos(mA, mE, 3.2, mRot, t, 0, 0);
    const moon    = { x: planet.x + moonRel.x, y: planet.y + moonRel.y };
    if (!reduceMotion) {
      pmTrailMoon.push({ ...moon });
      if (pmTrailMoon.length > 16) pmTrailMoon.shift();
      drawTrail(ctx, pmTrailMoon, 0.8, muted);
    }

    // Draw planet — gradient sphere
    const pg = ctx.createRadialGradient(planet.x - 1, planet.y - 1.5, 0, planet.x, planet.y, 5);
    pg.addColorStop(0, '#ffffff');
    pg.addColorStop(0.5, text);
    pg.addColorStop(1,   rgba(text, 0));
    ctx.beginPath(); ctx.arc(planet.x, planet.y, 5, 0, Math.PI * 2);
    ctx.fillStyle = pg; ctx.fill();

    // Draw moon
    ctx.beginPath(); ctx.arc(moon.x, moon.y, 2, 0, Math.PI * 2);
    ctx.fillStyle = muted; ctx.fill();
  }

  // ── Canvas 2: Binary Stars ────────────────────────────────────────────────
  const bs = setupCanvas('canvas-bs', 120);
  const bsTrailA: Pt[] = [];
  const bsTrailB: Pt[] = [];

  function drawBS(t: number) {
    if (!bs) return;
    const { ctx, S, CX, CY } = bs;
    const text   = cssVar('--text')   || '#1a1a1a';
    const accent = cssVar('--accent') || '#1E40AF';

    ctx.clearRect(0, 0, S, S);

    // Both stars orbit the common barycenter (CX, CY)
    // Mass ratio ≈ 1.25 → aA=26, aB=21  |  period T=10s
    const aA = 26, aB = 21, e = 0.09, T = 10;
    const starA = keplerPos(aA, e, T, 0,       t,       CX, CY);
    const starB = keplerPos(aB, e, T, Math.PI, t,       CX, CY); // opposite phase = π offset

    // Orbit ellipses
    drawOrbitEllipse(ctx, aA, e, 0, CX, CY, accent, 0.15);
    drawOrbitEllipse(ctx, aB, e, 0, CX, CY, text,   0.15);

    // Dashed gravitational connecting line
    ctx.beginPath();
    ctx.moveTo(starA.x, starA.y);
    ctx.lineTo(starB.x, starB.y);
    ctx.strokeStyle = text;
    ctx.globalAlpha = 0.10;
    ctx.lineWidth   = 0.6;
    ctx.setLineDash([2, 3]);
    ctx.stroke();
    ctx.globalAlpha = 1;
    ctx.setLineDash([]);

    // Barycenter dot
    ctx.beginPath(); ctx.arc(CX, CY, 1.5, 0, Math.PI * 2);
    ctx.fillStyle = text; ctx.globalAlpha = 0.25; ctx.fill();
    ctx.globalAlpha = 1;

    // Trails
    if (!reduceMotion) {
      bsTrailA.push({ ...starA });
      if (bsTrailA.length > 28) bsTrailA.shift();
      drawTrail(ctx, bsTrailA, 1.1, accent);

      bsTrailB.push({ ...starB });
      if (bsTrailB.length > 28) bsTrailB.shift();
      drawTrail(ctx, bsTrailB, 1.1, text);
    }

    // Star A — accent color with glow
    const ga = ctx.createRadialGradient(starA.x - 1, starA.y - 1.5, 0, starA.x, starA.y, 9);
    ga.addColorStop(0,   '#ffffff');
    ga.addColorStop(0.4, accent);
    ga.addColorStop(1,   rgba(accent, 0));
    ctx.beginPath(); ctx.arc(starA.x, starA.y, 9, 0, Math.PI * 2);
    ctx.fillStyle = ga; ctx.fill();
    ctx.beginPath(); ctx.arc(starA.x, starA.y, 4, 0, Math.PI * 2);
    ctx.fillStyle = accent; ctx.fill();

    // Star B — text color with glow
    const gb = ctx.createRadialGradient(starB.x - 1, starB.y - 1.5, 0, starB.x, starB.y, 7);
    gb.addColorStop(0,   '#ffffff');
    gb.addColorStop(0.4, text);
    gb.addColorStop(1,   rgba(text, 0));
    ctx.beginPath(); ctx.arc(starB.x, starB.y, 7, 0, Math.PI * 2);
    ctx.fillStyle = gb; ctx.fill();
    ctx.beginPath(); ctx.arc(starB.x, starB.y, 3.5, 0, Math.PI * 2);
    ctx.fillStyle = text; ctx.fill();
  }

  // ── Canvas 3: Black Hole + Gravitational Lensing ──────────────────────────
  const bh = setupCanvas('canvas-bh', 120);

  // Precomputed bezier lensing ray control points [x1,y1, cp1x,cp1y, cp2x,cp2y, x2,y2]
  // Canvas 120×120, BH at (60,60), event horizon r=17
  // All rays have impact parameter > 22 (outside photon sphere at ~22px)
  const lensRays: number[][] = [
    // Above BH — increasing deflection as impact param shrinks
    [  0, 11,  42, 9,   84, 13, 120, 15 ],  // impact≈49, gentle
    [  0, 21,  40, 17,  82, 19, 120, 25 ],  // impact≈39, moderate
    [  0, 31,  36, 24,  76, 20, 118, 30 ],  // impact≈29, significant
    [  0, 38,  30, 28,  64, 14, 105,  5 ],  // impact≈22, strong near photon sphere
    // Below BH — mirrored
    [  0, 89,  40, 93,  84, 97, 120, 91 ],
    [  0, 99,  42, 101, 82,105, 120,105 ],
    [  0,109,  35,113,  74,109, 108,118 ],
    // Right-to-left pass
    [120, 15,  82, 12,  40, 16,   0, 19 ],
    [120, 32,  80, 25,  38, 26,   0, 33 ],
  ];

  function drawBH(t: number) {
    if (!bh) return;
    const { ctx, S, CX, CY } = bh;
    const text   = cssVar('--text')   || '#1a1a1a';
    const accent = cssVar('--accent') || '#1E40AF';
    const bg     = cssVar('--bg')     || '#FAF9F6';

    ctx.clearRect(0, 0, S, S);

    // Accretion disk — slowly rotating tilted ellipse with gradient
    const diskRot = t * 0.35;
    ctx.save();
    ctx.translate(CX, CY);
    ctx.rotate(diskRot);
    const dg = ctx.createRadialGradient(0, 0, 16, 0, 0, 30);
    dg.addColorStop(0,   rgba(accent, 0));
    dg.addColorStop(0.5, rgba(accent, 0.82));
    dg.addColorStop(1,   rgba(accent, 0));
    ctx.beginPath(); ctx.ellipse(0, 0, 30, 7, 0, 0, Math.PI * 2);
    ctx.fillStyle = dg; ctx.fill();
    ctx.restore();

    // Lensing rays — animated dash offset to simulate flowing light
    const dashSpeed = 55; // px / s
    const dashPat   = 5;
    const gapPat    = 138;
    ctx.lineWidth = 1.4;
    ctx.setLineDash([dashPat, gapPat]);

    for (let i = 0; i < lensRays.length; i++) {
      const ray    = lensRays[i];
      const phase  = (i * 19) % (dashPat + gapPat);
      const offset = -((t * dashSpeed + phase) % (dashPat + gapPat));
      ctx.lineDashOffset = offset;
      const alpha = 0.60 + 0.20 * Math.sin(t * 0.6 + i * 0.9);
      ctx.globalAlpha  = alpha;
      ctx.strokeStyle  = text;
      ctx.beginPath();
      ctx.moveTo(ray[0], ray[1]);
      ctx.bezierCurveTo(ray[2], ray[3], ray[4], ray[5], ray[6], ray[7]);
      ctx.stroke();
    }
    ctx.globalAlpha    = 1;
    ctx.setLineDash([]);
    ctx.lineDashOffset = 0;

    // Event horizon — background-color disc erases everything inside it
    const ehGrad = ctx.createRadialGradient(CX, CY, 14, CX, CY, 25);
    ehGrad.addColorStop(0,   bg);
    ehGrad.addColorStop(0.6, rgba(bg, 0.92));
    ehGrad.addColorStop(1,   rgba(bg, 0));
    ctx.beginPath(); ctx.arc(CX, CY, 25, 0, Math.PI * 2);
    ctx.fillStyle = ehGrad; ctx.fill();
    // Hard edge
    ctx.beginPath(); ctx.arc(CX, CY, 17, 0, Math.PI * 2);
    ctx.fillStyle = bg; ctx.fill();
    // Thin ring to make BH edge readable in light mode
    ctx.beginPath(); ctx.arc(CX, CY, 17, 0, Math.PI * 2);
    ctx.strokeStyle = text; ctx.globalAlpha = 0.45;
    ctx.lineWidth = 1.2; ctx.setLineDash([]); ctx.stroke();
    ctx.globalAlpha = 1;

    // Photon ring — partial arc slowly sweeping around the BH
    const ringAngle = t * 0.75;
    ctx.beginPath();
    ctx.arc(CX, CY, 22, ringAngle, ringAngle + Math.PI * 1.3);
    ctx.strokeStyle = accent; ctx.globalAlpha = 0.95;
    ctx.lineWidth = 2.2; ctx.stroke();
    ctx.globalAlpha = 1;
  }

  // ── Single shared animation loop ──────────────────────────────────────────
  let startTime: number | null = null;

  function loop(ts: number) {
    if (startTime === null) startTime = ts;
    const t = reduceMotion ? 0 : (ts - startTime) / 1000;

    drawPM(t);
    drawBS(t);
    drawBH(t);

    if (!reduceMotion) requestAnimationFrame(loop);
  }

  requestAnimationFrame(loop);
})();
</script>
