---
<!--
  OrbitalSimulation — canvas-based 2-body Keplerian orbit.
  Physics: Newton-Raphson Kepler equation solver, real elliptical orbits.
  Trail: last 20 positions per body, fading opacity.
  Colors: read from CSS custom properties at runtime.
  Reduced-motion: renders a single static frame, no rAF loop.
-->
<div class="flex flex-col items-center gap-3 py-10 border-t border-edge">
  <canvas
    id="orbital-canvas"
    width="300"
    height="160"
    aria-label="2-body Keplerian orbital simulation"
    role="img"
    class="block"
  ></canvas>
  <p class="font-mono text-xs text-subtle text-center">
    2-BODY KEPLERIAN · a₁=40 e=0.3 T=8s · a₂=70 e=0.55 T=15s
  </p>
</div>

<script>
  const canvas = document.getElementById('orbital-canvas') as HTMLCanvasElement | null;
  if (!canvas) throw new Error('orbital-canvas not found');
  const ctx = canvas.getContext('2d')!;

  const W = canvas.width;
  const H = canvas.height;
  const CX = W / 2;
  const CY = H / 2;

  // ── Orbital elements ────────────────────────────────────────────────────
  const bodies = [
    { a: 40, e: 0.3,  T: 8,  rot: 0,                  trail: [] as {x:number,y:number}[] },
    { a: 70, e: 0.55, T: 15, rot: Math.PI / 6,         trail: [] as {x:number,y:number}[] }, // 30°
  ];

  // ── Kepler solver ────────────────────────────────────────────────────────
  function solveKepler(M: number, e: number): number {
    let E = M; // initial guess
    for (let i = 0; i < 5; i++) {
      E = E - (E - e * Math.sin(E) - M) / (1 - e * Math.cos(E));
    }
    return E;
  }

  function keplerPos(a: number, e: number, T: number, rot: number, t: number) {
    const M = (2 * Math.PI * t) / T;
    const E = solveKepler(M, e);
    const nu = 2 * Math.atan2(Math.sqrt(1 + e) * Math.sin(E / 2), Math.sqrt(1 - e) * Math.cos(E / 2));
    const r  = a * (1 - e * Math.cos(E));
    return {
      x: CX + r * Math.cos(nu + rot),
      y: CY + r * Math.sin(nu + rot),
    };
  }

  // ── Read CSS tokens at paint time ─────────────────────────────────────────
  function cssVar(name: string): string {
    return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
  }

  // ── Draw the faint orbital ellipse (computed once) ─────────────────────
  function drawOrbit(a: number, e: number, rot: number, strokeColor: string) {
    const b = a * Math.sqrt(1 - e * e);       // semi-minor axis
    const c = a * e;                           // focus offset

    ctx.save();
    ctx.translate(CX - c * Math.cos(rot), CY - c * Math.sin(rot));
    ctx.rotate(rot);
    ctx.beginPath();
    ctx.ellipse(0, 0, a, b, 0, 0, Math.PI * 2);
    ctx.strokeStyle = strokeColor;
    ctx.lineWidth = 0.5;
    ctx.setLineDash([3, 4]);
    ctx.stroke();
    ctx.restore();
  }

  // ── Central star with subtle radial glow ─────────────────────────────────
  function drawStar(accentColor: string) {
    const grad = ctx.createRadialGradient(CX, CY, 0, CX, CY, 12);
    grad.addColorStop(0,   accentColor);
    grad.addColorStop(0.35, accentColor + '88');
    grad.addColorStop(1,   accentColor + '00');
    ctx.beginPath();
    ctx.arc(CX, CY, 12, 0, Math.PI * 2);
    ctx.fillStyle = grad;
    ctx.fill();
    // Solid core
    ctx.beginPath();
    ctx.arc(CX, CY, 4, 0, Math.PI * 2);
    ctx.fillStyle = accentColor;
    ctx.fill();
  }

  // ── Draw trail ────────────────────────────────────────────────────────────
  function drawTrail(trail: {x:number,y:number}[], bodyColor: string) {
    const len = trail.length;
    for (let i = 1; i < len; i++) {
      const alpha = (i / len) * 0.8;
      ctx.beginPath();
      ctx.arc(trail[i].x, trail[i].y, 1, 0, Math.PI * 2);
      ctx.fillStyle = bodyColor.replace(')', `, ${alpha})`).replace('rgb', 'rgba');
      ctx.fill();
    }
  }

  const MAX_TRAIL = 20;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  let startTime: number | null = null;

  function render(ts: number) {
    if (startTime === null) startTime = ts;
    const t = reduceMotion ? 0 : (ts - startTime) / 1000; // seconds

    ctx.clearRect(0, 0, W, H);

    // Resolve colors each frame so dark-mode toggle is picked up
    const textColor   = cssVar('--text')   || '#1a1a1a';
    const accentColor = cssVar('--accent') || '#1E40AF';
    const pathColor   = textColor;

    // Orbital paths (drawn under everything)
    ctx.globalAlpha = 0.25;
    for (const b of bodies) drawOrbit(b.a, b.e, b.rot, pathColor);
    ctx.globalAlpha = 1;

    // Central star
    drawStar(accentColor);

    // Bodies + trails
    for (const b of bodies) {
      const pos = keplerPos(b.a, b.e, b.T, b.rot, t);

      // Update trail (skip if reduced motion — single frame, no trail needed)
      if (!reduceMotion) {
        b.trail.push(pos);
        if (b.trail.length > MAX_TRAIL) b.trail.shift();
        drawTrail(b.trail, textColor.startsWith('#')
          ? hexToRgb(textColor)
          : textColor);
      }

      // Body dot
      ctx.beginPath();
      ctx.arc(pos.x, pos.y, 2.5, 0, Math.PI * 2);
      ctx.fillStyle = textColor;
      ctx.fill();
    }

    if (!reduceMotion) requestAnimationFrame(render);
  }

  // Minimal hex→rgb for trail alpha blending
  function hexToRgb(hex: string): string {
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    return `rgb(${r}, ${g}, ${b})`;
  }

  requestAnimationFrame(render);
</script>
