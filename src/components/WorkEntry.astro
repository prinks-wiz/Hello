---
interface Props {
  org:         string;
  role:        string;
  startDate:   Date;
  endDate?:    Date | null;
  description: string;
  techStack?:  string[];
  location?:   string;
}
const { org, role, startDate, endDate, description, techStack, location } = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });

const dateRange = `${fmt(startDate)} to ${endDate ? fmt(endDate) : 'Present'}`;
---
<article class="border-b border-edge py-8">
  <div class="flex items-start justify-between gap-4 mb-3">
    <div class="flex items-start gap-4">
      <!-- Logo placeholder: swap with <img> when real logos are ready -->
      <div
        class="w-10 h-10 rounded-md shrink-0 mt-0.5"
        style="background-color: color-mix(in srgb, var(--accent) 10%, transparent);"
        aria-hidden="true"
      ></div>
      <div>
        <h3 class="text-base font-semibold text-content">{role}</h3>
        <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mt-0.5">
          <span class="text-sm text-subtle">{org}</span>
          {location && (
            <>
              <span class="text-subtle" aria-hidden="true">·</span>
              <span class="font-mono text-xs text-subtle">{location}</span>
            </>
          )}
        </div>
      </div>
    </div>
    <time class="font-mono text-xs text-subtle shrink-0 mt-0.5 text-right">
      {dateRange}
    </time>
  </div>

  <p class="text-sm text-subtle leading-relaxed mb-4 pl-14">{description}</p>

  {techStack && techStack.length > 0 && (
    <ul class="flex flex-wrap gap-2 list-none m-0 p-0 pl-14" aria-label="Tech stack">
      {techStack.map(tech => (
        <li>
          <span class="font-mono text-xs text-subtle border border-edge px-2 py-0.5">
            {tech}
          </span>
        </li>
      ))}
    </ul>
  )}
</article>
