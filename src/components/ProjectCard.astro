---
interface Props {
  title:           string;
  slug:            string;
  summary:         string;
  date:            Date;
  techStack:       string[];
  featured?:       boolean;
  stat?:           string;
  domainTag?:      string;
  cardDescription?: string;
}
const { title, slug, summary, date, techStack, featured = false, stat, domainTag, cardDescription } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
import { url } from '../utils/url';
---
<article class="border-b border-edge border-l-2 py-8 group pl-4" style="border-left-color: var(--accent);">

  <!-- Top row: domain tag + GitHub icon -->
  <div class="flex items-center justify-between gap-4 mb-3">
    {domainTag ? (
      <span
        class="font-mono text-xs uppercase tracking-widest px-2 py-0.5"
        style="background-color: #1e3a5f; color: #e2e8f0;"
      >        {domainTag}
      </span>
    ) : <span />}
    <div class="flex items-center gap-3">
      {/* TODO: fix link — currently placeholder */}
      <a
        href="#"
        aria-label="View on GitHub"
        class="transition-colors text-subtle hover:text-content"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65S9 17.44 9 18v4"/>
          <path d="M9 18c-4.51 2-5-2-7-2"/>
        </svg>
      </a>
      <time class="font-mono text-xs text-subtle shrink-0" datetime={date.toISOString()}>
        {formattedDate}
      </time>
    </div>
  </div>

  <a href={url(`/projects/${slug}`)} class="block" tabindex="0">
    <!-- Title -->
    <h3 class="text-xl font-semibold text-content group-hover:text-accent transition-colors mb-1 flex items-center gap-2">
      {title}
      {featured && <span class="font-mono text-xs text-accent" aria-label="Featured">★</span>}
    </h3>

    <!-- Impact stat -->
    {stat && (
      <p class="font-mono text-sm text-subtle mb-3">{stat}</p>
    )}

    <!-- Description: use cardDescription if available, fall back to summary -->
    <p class="text-sm text-subtle leading-relaxed mb-4">{cardDescription ?? summary}</p>
  </a>

  <!-- Tech stack -->
  <ul class="flex flex-wrap gap-2 list-none m-0 p-0" aria-label="Tech stack">
    {techStack.map(tech => (
      <li>
        <span class="font-mono text-xs text-subtle border border-edge px-2 py-0.5">
          {tech}
        </span>
      </li>
    ))}
  </ul>
</article>
