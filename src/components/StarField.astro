---
---
<!--
  Sparse decorative starfield — hero section only.
  28 hardcoded dot positions distributed across the full hero viewport.
  Opacity adapts to color scheme via CSS custom property:
    light mode: 0.35   dark mode: 0.50
  Dot radii vary (0.5–2px) to suggest depth.
-->
<style>
  :root { --sf-opacity: 0.35; }
  .dark  { --sf-opacity: 0.50; }
</style>

<svg
  id="starfield-svg"
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 1000 380"
  preserveAspectRatio="xMidYMid slice"
  aria-hidden="true"
  role="presentation"
  class="absolute inset-0 w-full h-full pointer-events-none select-none"
  style="z-index: 0;"
>
  <g fill="var(--text)" opacity="var(--sf-opacity)">
    <!-- top third -->
    <circle cx="38"  cy="18"  r="1.0" />
    <circle cx="112" cy="44"  r="0.5" />
    <circle cx="189" cy="12"  r="1.5" />
    <circle cx="267" cy="58"  r="1.0" />
    <circle cx="341" cy="28"  r="2.0" />
    <circle cx="456" cy="9"   r="0.5" />
    <circle cx="523" cy="52"  r="1.0" />
    <circle cx="612" cy="21"  r="1.5" />
    <circle cx="698" cy="38"  r="0.5" />
    <circle cx="774" cy="14"  r="2.0" />
    <circle cx="851" cy="47"  r="1.0" />
    <circle cx="943" cy="22"  r="1.5" />
    <!-- middle band -->
    <circle cx="72"  cy="165" r="0.5" />
    <circle cx="158" cy="190" r="1.5" />
    <circle cx="304" cy="145" r="1.0" />
    <circle cx="419" cy="200" r="2.0" />
    <circle cx="547" cy="155" r="0.5" />
    <circle cx="661" cy="185" r="1.0" />
    <circle cx="739" cy="140" r="1.5" />
    <circle cx="888" cy="175" r="1.0" />
    <circle cx="971" cy="160" r="0.5" />
    <!-- lower third -->
    <circle cx="55"  cy="295" r="1.0" />
    <circle cx="183" cy="318" r="0.5" />
    <circle cx="316" cy="280" r="2.0" />
    <circle cx="487" cy="340" r="1.0" />
    <circle cx="634" cy="300" r="1.5" />
    <circle cx="789" cy="325" r="0.5" />
    <circle cx="912" cy="285" r="1.0" />
  </g>
</svg>

<script>
  const sf = document.getElementById('starfield-svg') as SVGElement | null;
  if (sf && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let ticking = false;
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            sf.style.transform = `translateY(${window.scrollY * -0.3}px)`;
            ticking = false;
          });
          ticking = true;
        }
      },
      { passive: true }
    );
  }
</script>
