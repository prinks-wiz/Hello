<!--
  SideStarFields — two fixed side panels framing the content column.
  Bigger stars, radial gradient shine, slow twinkling, blur glow on anchors.
  Parallax: 0.2× scroll speed, rAF throttled, disabled for reduced-motion.
-->
<style>
  :root  { --ssf-op: 0.82; --ssf-anchor-op: 1.0; }
  .dark  { --ssf-op: 0.95; --ssf-anchor-op: 1.0; }

  .side-sf {
    position: fixed;
    top: 0;
    width: 15vw;
    height: 100vh;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  #sf-left  { left: 0; }
  #sf-right { right: 0; }

  .side-sf svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Regular dots */
  .dot { opacity: var(--ssf-op); fill: var(--text); }

  /* Hard blink — step-start gives instant on/off like a terminal */
  @keyframes blink-star {
    0%, 100% { opacity: var(--ssf-op); }
    50%       { opacity: 0.05; }
  }
  .t1 { animation: blink-star 4.8s step-start 0.4s  infinite; }
  .t2 { animation: blink-star 6.5s step-start 1.1s  infinite; }
  .t3 { animation: blink-star 4.1s step-start 2.3s  infinite; }
  .t4 { animation: blink-star 8.0s step-start 0.7s  infinite; }
  .t5 { animation: blink-star 6.1s step-start 1.8s  infinite; }

  /* Anchor stars — plain filled circles, hard blink, full opacity */
  .anchor { fill: var(--text); opacity: var(--ssf-anchor-op); }

  @keyframes blink-anchor {
    0%, 100% { opacity: var(--ssf-anchor-op); }
    50%       { opacity: 0.05; }
  }
  .ap1 { animation: blink-anchor 6.8s step-start 0.0s  infinite; }
  .ap2 { animation: blink-anchor 8.6s step-start 1.4s  infinite; }
  .ap3 { animation: blink-anchor 6.2s step-start 2.8s  infinite; }
  .ap4 { animation: blink-anchor 10.0s step-start 0.9s  infinite; }
  .ap5 { animation: blink-anchor 8.1s step-start 2.0s  infinite; }
</style>

