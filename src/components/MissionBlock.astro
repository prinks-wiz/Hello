---
import { missionStatus } from '../config';
const { mission, status, timeline, location } = missionStatus;
---
<!--
  Mission status block — reads from src/config.ts.
  All text in JetBrains Mono; hairline borders separate the block.
  Label column is fixed-width so values align cleanly.
-->
<div class="border-t border-b border-edge font-mono text-sm py-8 my-8">
  <dl class="flex flex-col gap-2">
    <div class="flex items-baseline gap-0">
      <dt class="text-subtle uppercase tracking-[0.1em] w-28 shrink-0">MISSION</dt>
      <dd class="text-content">{mission}</dd>
    </div>
    <div class="flex items-baseline gap-0">
      <dt class="text-subtle uppercase tracking-[0.1em] w-28 shrink-0">STATUS</dt>
      <dd class="text-content">{status}</dd>
    </div>
    <div class="flex items-baseline gap-0">
      <dt class="text-subtle uppercase tracking-[0.1em] w-28 shrink-0">TIMELINE</dt>
      <dd class="text-content">{timeline}</dd>
    </div>
    <div class="flex items-baseline gap-0">
      <dt class="text-subtle uppercase tracking-[0.1em] w-28 shrink-0">LOCATION</dt>
      <dd class="text-content">{location}</dd>
    </div>
  </dl>
</div>
